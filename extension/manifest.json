{
  "manifest_version": 3,
  "name": "OneDrive Local Opener",
  "version": "1.0.0",
  "description": "Opens OneDrive-synced files in their local application instead of downloading.",
  "key": "",
  "permissions": ["nativeMessaging", "storage"],
  "background": {
    "service_worker": "dist/background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://*.sharepoint.com/*"],
      "js": ["dist/content.js"],
      "run_at": "document_idle"
    }
  ],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "OneDrive Local Opener"
  }
}
