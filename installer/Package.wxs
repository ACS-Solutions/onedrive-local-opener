<?xml version="1.0" encoding="utf-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui"
     xmlns:util="http://wixtoolset.org/schemas/v4/wxs/util">

  <!--
    Single MSI — per-user by default; user can switch to per-machine in the installer dialog.

    Silent install for corporate deployment:
      Per-user    — msiexec /i OneDriveLocalOpener.msi MSIINSTALLPERUSER=1 /quiet
      Per-machine — msiexec /i OneDriveLocalOpener.msi ALLUSERS=1 /quiet
  -->

  <Package Name="OneDrive Local Opener"
           Manufacturer="ACS Solutions Ltd"
           Version="1.0.0"
           UpgradeCode="E5F2A3B1-7C4D-4E8F-9A2B-3C5D6E7F8A9B"
           Language="1033"
           Codepage="1252">

    <SummaryInformation Description="Opens OneDrive-synced files in their local application instead of downloading." />
    <MajorUpgrade DowngradeErrorMessage="A newer version of OneDrive Local Opener is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <!-- WixUI_Advanced default scope; the dialog lets the user change it. -->
    <Property Id="ApplicationFolderName" Value="OneDrive Local Opener" />
    <Property Id="WixAppFolder" Value="WixPerUserFolder" />

    <Feature Id="ProductFeature" Title="OneDrive Local Opener" Level="1">
      <ComponentGroupRef Id="HostFiles_User" />
      <ComponentGroupRef Id="HostFiles_Machine" />
      <ComponentGroupRef Id="PerUserRegistry" />
      <ComponentGroupRef Id="PerMachineRegistry" />
    </Feature>

    <!--
      Post-install: run Host.exe register with the correct scope.
      Conditions use ALLUSERS rather than WixAppFolder because WixAppFolder is only
      set during the UI sequence and is absent in silent installs.
      WixUI_Advanced sets ALLUSERS=1 when the user picks per-machine.
    -->
    <SetProperty Id="RegisterNMH_User"
                 Value="&quot;[APPLICATIONFOLDER]Host.exe&quot; register --scope user"
                 Before="RegisterNMH_User" Sequence="execute" />
    <CustomAction Id="RegisterNMH_User"
                  BinaryRef="Wix4UtilCA_X64"
                  DllEntry="WixQuietExec64"
                  Execute="deferred"
                  Impersonate="no"
                  Return="check" />

    <SetProperty Id="RegisterNMH_Machine"
                 Value="&quot;[APPLICATIONFOLDER]Host.exe&quot; register --scope machine"
                 Before="RegisterNMH_Machine" Sequence="execute" />
    <CustomAction Id="RegisterNMH_Machine"
                  BinaryRef="Wix4UtilCA_X64"
                  DllEntry="WixQuietExec64"
                  Execute="deferred"
                  Impersonate="no"
                  Return="check" />

    <!-- Pre-uninstall: run Host.exe unregister -->
    <SetProperty Id="UnregisterNMH_User"
                 Value="&quot;[APPLICATIONFOLDER]Host.exe&quot; unregister --scope user"
                 Before="UnregisterNMH_User" Sequence="execute" />
    <CustomAction Id="UnregisterNMH_User"
                  BinaryRef="Wix4UtilCA_X64"
                  DllEntry="WixQuietExec64"
                  Execute="deferred"
                  Impersonate="no"
                  Return="ignore" />

    <SetProperty Id="UnregisterNMH_Machine"
                 Value="&quot;[APPLICATIONFOLDER]Host.exe&quot; unregister --scope machine"
                 Before="UnregisterNMH_Machine" Sequence="execute" />
    <CustomAction Id="UnregisterNMH_Machine"
                  BinaryRef="Wix4UtilCA_X64"
                  DllEntry="WixQuietExec64"
                  Execute="deferred"
                  Impersonate="no"
                  Return="ignore" />

    <InstallExecuteSequence>
      <Custom Action="RegisterNMH_User"    After="InstallFiles"  Condition="NOT Installed AND NOT REMOVE AND NOT ALLUSERS = &quot;1&quot;" />
      <Custom Action="RegisterNMH_Machine" After="InstallFiles"  Condition="NOT Installed AND NOT REMOVE AND ALLUSERS = &quot;1&quot;" />
      <Custom Action="UnregisterNMH_User"    Before="RemoveFiles" Condition="Installed AND REMOVE~=&quot;ALL&quot; AND NOT ALLUSERS = &quot;1&quot;" />
      <Custom Action="UnregisterNMH_Machine" Before="RemoveFiles" Condition="Installed AND REMOVE~=&quot;ALL&quot; AND ALLUSERS = &quot;1&quot;" />
    </InstallExecuteSequence>

    <!-- WixUI_Advanced: Welcome → (optional) scope selection → Install → Finish -->
    <ui:WixUI Id="WixUI_Advanced" />
    <WixVariable Id="WixUILicenseRtf" Value="License.rtf" />
  </Package>

  <!-- ═══ Directory structure ════════════════════════════════════════════════════ -->
  <Fragment>
    <!-- Per-user:    %LOCALAPPDATA%\Programs\OneDriveLocalOpener -->
    <StandardDirectory Id="LocalAppDataFolder">
      <Directory Id="LocalAppDataProgramsFolder" Name="Programs">
        <Directory Id="WixPerUserFolder" Name="OneDriveLocalOpener" />
      </Directory>
    </StandardDirectory>

    <!-- Per-machine: %ProgramFiles%\ACS Solutions\OneDriveLocalOpener -->
    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="AcsSolutionsFolder" Name="ACS Solutions">
        <Directory Id="WixPerMachineFolder" Name="OneDriveLocalOpener" />
      </Directory>
    </StandardDirectory>
  </Fragment>

  <!-- ═══ File components ════════════════════════════════════════════════════════ -->
  <Fragment>
    <!--
      Files are duplicated across two conditioned component groups so WiX installs
      to the correct directory regardless of scope. Only one group is active at runtime.
    -->
    <ComponentGroup Id="HostFiles_User" Directory="WixPerUserFolder">
      <!--
        ICE38: components in the user profile must use a registry KeyPath, not a file KeyPath.
        ICE64: directories in the user profile must have RemoveFolder entries for uninstall cleanup.
        RemoveFolder for Programs is safe — Windows silently skips non-empty directories.
      -->
      <Component Id="HostExe_User" Guid="A1B2C3D4-E5F6-4A7B-8C9D-E0F1A2B3C4D5"
                 Condition="WixAppFolder = &quot;WixPerUserFolder&quot;">
        <File Source="$(HostPublishDir)Host.exe" />
        <RegistryValue Root="HKCU" Key="Software\ACS Solutions\OneDriveLocalOpener"
                       Name="InstallDir" Type="string" Value="[WixPerUserFolder]" KeyPath="yes" />
        <RemoveFolder Id="RemoveWixPerUserFolder" Directory="WixPerUserFolder" On="uninstall" />
        <RemoveFolder Id="RemoveLocalAppDataProgramsFolder" Directory="LocalAppDataProgramsFolder" On="uninstall" />
      </Component>
      <Component Id="RuntimeConfig_User" Guid="B2C3D4E5-F6A7-4B8C-9D0E-F1A2B3C4D5E6"
                 Condition="WixAppFolder = &quot;WixPerUserFolder&quot;">
        <File Source="$(HostPublishDir)Host.runtimeconfig.json" />
        <RegistryValue Root="HKCU" Key="Software\ACS Solutions\OneDriveLocalOpener"
                       Name="RuntimeConfigPath" Type="string" Value="[WixPerUserFolder]Host.runtimeconfig.json" KeyPath="yes" />
      </Component>
    </ComponentGroup>

    <ComponentGroup Id="HostFiles_Machine" Directory="WixPerMachineFolder">
      <Component Id="HostExe_Machine" Guid="A2B3C4D5-E6F7-4B8C-9D0E-F1A2B3C4D5E6"
                 Condition="WixAppFolder = &quot;WixPerMachineFolder&quot;">
        <File Source="$(HostPublishDir)Host.exe" KeyPath="yes" />
      </Component>
      <Component Id="RuntimeConfig_Machine" Guid="B3C4D5E6-F7A8-4C9D-0E1F-A2B3C4D5E6F7"
                 Condition="WixAppFolder = &quot;WixPerMachineFolder&quot;">
        <File Source="$(HostPublishDir)Host.runtimeconfig.json" KeyPath="yes" />
      </Component>
    </ComponentGroup>
  </Fragment>

  <!-- ═══ Registry components ════════════════════════════════════════════════════ -->
  <Fragment>
    <!-- Per-user: HKCU — NMH registration for Chrome and Edge -->
    <ComponentGroup Id="PerUserRegistry" Directory="WixPerUserFolder">
      <Component Id="ChromeNmh_User" Guid="C3D4E5F6-A7B8-4C9D-0E1F-A2B3C4D5E6F7"
                 Condition="WixAppFolder = &quot;WixPerUserFolder&quot;">
        <RegistryKey Root="HKCU"
                     Key="Software\Google\Chrome\NativeMessagingHosts\uk.co.acs_solutions.onedrive_local_opener">
          <RegistryValue Type="string" Value="[WixPerUserFolder]nmh-manifest.json" KeyPath="yes" />
        </RegistryKey>
      </Component>
      <Component Id="EdgeNmh_User" Guid="D4E5F6A7-B8C9-4D0E-1F2A-B3C4D5E6F7A8"
                 Condition="WixAppFolder = &quot;WixPerUserFolder&quot;">
        <RegistryKey Root="HKCU"
                     Key="Software\Microsoft\Edge\NativeMessagingHosts\uk.co.acs_solutions.onedrive_local_opener">
          <RegistryValue Type="string" Value="[WixPerUserFolder]nmh-manifest.json" KeyPath="yes" />
        </RegistryKey>
      </Component>
    </ComponentGroup>

    <!-- Per-machine: HKLM — NMH registration for Chrome and Edge -->
    <ComponentGroup Id="PerMachineRegistry" Directory="WixPerMachineFolder">
      <Component Id="ChromeNmh_Machine" Guid="E5F6A7B8-C9D0-4E1F-2A3B-C4D5E6F7A8B9"
                 Condition="WixAppFolder = &quot;WixPerMachineFolder&quot;">
        <RegistryKey Root="HKLM"
                     Key="Software\Google\Chrome\NativeMessagingHosts\uk.co.acs_solutions.onedrive_local_opener">
          <RegistryValue Type="string" Value="[WixPerMachineFolder]nmh-manifest.json" KeyPath="yes" />
        </RegistryKey>
      </Component>
      <Component Id="EdgeNmh_Machine" Guid="F6A7B8C9-D0E1-4F2A-3B4C-D5E6F7A8B9C0"
                 Condition="WixAppFolder = &quot;WixPerMachineFolder&quot;">
        <RegistryKey Root="HKLM"
                     Key="Software\Microsoft\Edge\NativeMessagingHosts\uk.co.acs_solutions.onedrive_local_opener">
          <RegistryValue Type="string" Value="[WixPerMachineFolder]nmh-manifest.json" KeyPath="yes" />
        </RegistryKey>
      </Component>
    </ComponentGroup>
  </Fragment>

</Wix>
